<div class='container'>
    <h2>{{#if faq.id}}Edit FAQ{{else}}Create FAQ{{/if}}</h2>
    <form action="/faq/{{#if faq.id}}edit/{{faq.id}}{{else}}create{{/if}}" method="POST">
        <div>
            <label for="question">Question</label>
            <input type="text" name="question" value="{{faq.question}}" required />
        </div><br>
        <div>
            <label for="answer">Answer</label><br>
            <textarea name="answer" rows="4" required>{{faq.answer}}</textarea>
        </div>
        <br>
        <div class="text-center">
            <button type="submit" class='btn btn-primary'>{{#if faq.id}}Update FAQ{{else}}Create FAQ{{/if}}</button>
        </div>
    </form>
    {{#if faq.id}}
    <form action="/faq/delete/{{faq.id}}" method="POST">
        <div class="text-center mt-3">
            <button type="submit" class="btn btn-danger">Delete FAQ</button>
        </div>
    </form>
    {{/if}}

    {{#if errorMessage}}
    <p class="error-message" id="error-login">{{errorMessage}}</p>
    {{/if}}
</div>