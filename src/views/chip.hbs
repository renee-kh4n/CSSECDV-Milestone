<div class="container">
    <h2>{{title}}</h2>

    <div class="scroll">
        {{#each subChips}}

        <div class="card mb-3 p-3 d-flex justify-content-between align-items-start " style="cursor: pointer; display: flex; flex-direction: row; gap: 20px;">
            
            <a href="/chip/{{this.subchip_id}}" style="text-decoration: none; color: inherit; flex: 1;">
                <div>
                    <h5 class="mb-1">{{this.title}}</h5>
                    {{#if this.datetime}}
                    <small class="text-muted">{{this.datetime}}</small>
                    {{/if}}

                    {{#if this.description}}
                    <p class="mb-2 mt-2">{{this.description}}</p>
                    {{/if}}
                </div>
            </a>
            {{#if ../isAdmin}}
                <div class="d-flex flex-column gap-2 ms-3">
                    <a href="/chip/edit/{{this.subchip_id}}" class="btn btn-warning btn-sm">Edit</a>

                    <form action="/chip/delete/{{this.subchip_id}}" method="POST">
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                </div>
            {{/if}}

        </div>

        {{/each}}
    </div>

    {{#if isAdmin}}
        <div class="text-center mt-3">
            <a href="/chip/create" class="btn btn-primary">Create New SubChip</a>
        </div>
    {{/if}}
</div>