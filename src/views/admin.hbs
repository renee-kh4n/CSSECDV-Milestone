<div class="container">
    <h2>Admin Panel</h2>
    <div class="admin-actions">
        <a href="/admin/ban-users" class="btn btn-primary">Manage Banned Users</a>
    </div>
    <table class="admin-table">
        <thead>
            <tr>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Email</th>
                <th>Phone number</th>
                <th>Photo</th>
                <th>Role</th>
            </tr>
        </thead>
        <tbody>
            {{#each users}}
            <tr>
                <td>{{this.firstName}}</td>
                <td>{{this.lastName}}</td>
                <td>{{this.email}}</td>
                <td>+63{{this.phoneNumber}}</td>
                <td>
                    <img src="{{this.pfp}}" class="pfp" crossorigin>
                </td>
                <td>{{this.role}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>