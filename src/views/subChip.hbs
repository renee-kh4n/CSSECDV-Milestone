<div class="container mt-4">
    <h2>{{title}}</h2>

    <div class="scroll">
        {{#each posts}}
        <div class="card mb-3 p-3">
            <div class="d-flex align-items-center gap-2">
                <img src="{{this.pfp}}" class="pfp" crossorigin>

                <div>
                    <h5 class="mb-0">{{this.first_name}} {{this.last_name}}</h5>
                    {{#if this.created_at}}
                    <small class="text-muted">{{this.datetime}}</small>
                    {{/if}}
                </div>
            </div>

            <div class="card-body p-0">
                <p class="mb-2">{{this.content}}</p>

                {{#if this.isOwner}}
                <a href="/chip/edit/{{this.id}}" class="btn btn-warning btn-sm">Edit</a>
                <form action="/chip/delete/{{this.id}}" method="POST" style="display:inline;">
                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                </form>
                {{/if}}
            </div>
        </div>
        {{/each}}
    </div>

    <div class="text-center mt-3">
        <a href="/chip/{{title}}/create" class="btn btn-primary">Create New Post</a>
    </div>
</div>