<div class="container">
    <h2>{{title}}</h2>

    <div class="scroll">
        {{#each posts}}
        <div class="card mb-3 p-3">
            <div class="d-flex align-items-center gap-2">
                <img src="{{this.pfp}}" class="pfp" crossorigin>

                <div>
                    <h5 class="mb-0">{{this.first_name}} {{this.last_name}}</h5>
                    <small class="text-muted">{{this.datetime}}</small>
                </div>
            </div>

            <div class="card-body p-0">
                <div class="mb-2">
                    <img src="{{this.image}}" class="posts mw-100" alt="Post image" crossorigin>
                </div>

                <p class="fw-bold text-success mb-1">
                    Php {{this.price}}
                </p>

                <p class="mb-2">{{this.description}}</p>
                <p class="text-muted mb-2">
                    Average rating:
                    {{#if this.ratingCount}}
                        {{this.averageRating}}/5 ({{this.ratingCount}} rating{{#unless (eq this.ratingCount 1)}}s{{/unless}})
                    {{else}}
                        No ratings yet
                    {{/if}}
                </p>

                {{#if this.isOwner}}
                <a href="/chip/{{../subchip_id}}/edit/{{this.id}}" class="btn btn-warning btn-sm">Edit</a>
                <form action="/chip/{{../subchip_id}}/delete/{{this.id}}" method="POST" style="display:inline;">
                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                </form>
                {{else}}
                <form method="POST" action="/forum/rating/{{this.id}}">
                <div class="rating">
                    <input type="radio" name="rating" value="5" id="star5-{{this.id}}" {{#if (eq this.userRating 5)}}checked{{/if}}><label for="star5-{{this.id}}" title="5 stars"></label>

                    <input type="radio" name="rating" value="4" id="star4-{{this.id}}" {{#if (eq this.userRating 4)}}checked{{/if}}><label for="star4-{{this.id}}" title="4 stars" ></label>

                    <input type="radio" name="rating" value="3" id="star3-{{this.id}}" {{#if (eq this.userRating 3)}}checked{{/if}}><label for="star3-{{this.id}}" title="3 stars"></label>

                    <input type="radio" name="rating" value="2" id="star2-{{this.id}}" {{#if (eq this.userRating 2)}}checked{{/if}}><label for="star2-{{this.id}}" title="2 stars"></label>

                    <input type="radio" name="rating" value="1" id="star1-{{this.id}}" {{#if (eq this.userRating 1)}}checked{{/if}}><label for="star1-{{this.id}}" title="1 star"></label>
                </div>

                </form>
                {{/if}}

                <hr>

                <h6 class="mt-3">Comments</h6>

                {{#if this.comments.length}}
                    {{#each this.comments}}
                    <div class="comment-card border rounded p-2 mb-2">
                        <div class="d-flex align-items-center gap-2">
                            <img src="{{this.pfp}}" class="pfp" crossorigin>

                            <div>
                                <h6 class="mb-0">{{this.first_name}} {{this.last_name}}</h6>
                                <small class="text-muted">{{this.datetime}}</small>
                            </div>
                        </div>

                        <p class="mb-2 mt-2">{{this.content}}</p>

                        {{#if this.isOwner}}
                        <a href="/forum/{{this.post_id}}/edit/{{this.id}}" class="btn btn-warning btn-sm">Edit</a>
                        <form action="/forum/{{this.post_id}}/delete/{{this.id}}" method="POST" style="display:inline;">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>
                        {{/if}}
                    </div>
                    {{/each}}
                {{else}}
                    <p class="text-muted">No comments yet.</p>
                {{/if}}
                <a href="/forum/{{this.id}}/create" class="btn btn-primary btn-sm mt-2">
                    Add Comment
                </a>
            </div>
        </div>
        {{/each}}
    </div>

    <div class="text-center mt-3">
        <a href="/chip/{{subchip_id}}/create" class="btn btn-primary">Create New Post</a>
    </div>
</div>