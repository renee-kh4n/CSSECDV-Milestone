<div class="container">
    <h2>{{title}}</h2>

    <div class="scroll">
        {{#each announcements}}

        <div class="card mb-3 p-3 d-flex flex-row justify-content-between align-items-start custom-card">
            
            <div class="custom-chip">
                <h5 class="mb-1">{{this.title}}</h5>

                {{#if this.datetime}}
                <small class="text-muted">{{this.datetime}}</small>
                {{/if}}

                <p class="mb-2 mt-2">{{this.content}}</p>
            </div>

            {{#if ../isAdmin}}
            <div class="d-flex flex-column gap-2 ms-3">
                <a href="/announcement/edit/{{this.announcement_id}}" class="btn btn-warning btn-sm">Edit</a>

                <form action="/announcement/delete/{{this.announcement_id}}" method="POST">
                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                </form>
            </div>
            {{/if}}

        </div>

        {{/each}}
    </div>

    {{#if isAdmin}}
    <div class="text-center mt-3">
        <a href="/announcement/create" class="btn btn-primary">Create New Announcement</a>
    </div>
    {{/if}}
</div>